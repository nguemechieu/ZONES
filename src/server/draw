int TimeframeSeconds(int timeframe)
{
   switch(timeframe)
   {
      case PERIOD_M1:  return 60;
      case PERIOD_M5:  return 300;
      case PERIOD_M15: return 900;
      case PERIOD_M30: return 1800;
      case PERIOD_H1:  return 3600;
      case PERIOD_H4:  return 14400;
      case PERIOD_D1:  return 86400;
      default:         return 60;
   }
}

void ClearZoneObjects()
{
   for(int index = ObjectsTotal() - 1; index >= 0; index--)
   {
      string name = ObjectName(index);
      if(StringFind(name, ZonePrefix, 0) == 0)
         ObjectDelete(name);
   }
}

void DrawZoneRectangle(string name, datetime leftTime, datetime rightTime, double upper, double lower, color zoneColor, string label)
{
   if(ObjectFind(name) == -1)
      ObjectCreate(name, OBJ_RECTANGLE, 0, leftTime, upper, rightTime, lower);
   else
   {
      ObjectMove(name, 0, leftTime, upper);
      ObjectMove(name, 1, rightTime, lower);
   }

   ObjectSet(name, OBJPROP_COLOR, zoneColor);
   ObjectSet(name, OBJPROP_WIDTH, 1);
   ObjectSet(name, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSet(name, OBJPROP_BACK, true);

   string labelName = name + "_LABEL";
   if(ObjectFind(labelName) == -1)
      ObjectCreate(labelName, OBJ_TEXT, 0, leftTime, upper);
   else
      ObjectMove(labelName, 0, leftTime, upper);

   ObjectSetText(labelName, label, 8, "Arial", zoneColor);
}

string LineType(string wireLine)
{
   int separator = StringFind(wireLine, "|", 0);
   if(separator < 0)
      return wireLine;
   return StringSubstr(wireLine, 0, separator);
}

string CurrentTimeframeLabel()
{
   int chartPeriod = Period();
   if(chartPeriod <= PERIOD_M1)
      return "1M";
   if(chartPeriod <= PERIOD_M5)
      return "5M";
   return "1H";
}

bool WireBool(string value)
{
   return value == "true" || value == "1" || value == "yes";
}

datetime TimeFromOriginShift(int originShift)
{
   if(Bars <= 0)
      return TimeCurrent();

   if(originShift < 0)
      originShift = 0;
   if(originShift > Bars - 1)
      originShift = Bars - 1;

   return Time[originShift];
}

color ZoneColorForLine(string kind, string family, string status)
{
   if(status == "deleted")
      return clrSilver;
   if(kind == "liquidity")
      return LiquidityColor;
   if(kind == "support")
      return SupportColor;
   if(kind == "resistance")
      return ResistanceColor;
   if(kind == "supply")
      return family == "main" ? ResistanceColor : SupplyColor;
   if(kind == "demand")
      return family == "main" ? SupportColor : DemandColor;
   return clrSilver;
}

int ZoneWidthForLine(string family, string status)
{
   if(status == "deleted")
      return 1;
   if(family == "main" || family == "support_resistance")
      return 2;
   return 1;
}

color SwingColorForLine(string source, string kind)
{
   if(kind == "high")
      return source == "fractal" ? ResistanceColor : SupplyColor;
   return source == "fractal" ? SupportColor : DemandColor;
}

string ZoneLabelForLine(string timeframeLabel, string family, string kind, string strength, string status, string modeBias)
{
   string label = timeframeLabel + " ";

   if(family == "main")
      label += "MAIN ";
   else if(family == "temp")
      label += "TEMP ";
   else if(family == "support_resistance")
      label += "SR ";
   else if(family == "liquidity")
      label += "LIQ ";

   if(strength != "")
      label += strength + " ";

   if(kind != "")
      label += kind + " ";

   if(status == "deleted")
      label += "deleted";
   else if(modeBias != "")
      label += "[" + modeBias + "]";

   return label;
}

string SwingLabelForLine(string source, string label)
{
   return (source == "fractal" ? "FR " : "ZZ ") + label;
}

void DrawTextMarker(string name, datetime markerTime, double markerPrice, string label, color markerColor, int fontSize)
{
   if(ObjectFind(name) == -1)
      ObjectCreate(name, OBJ_TEXT, 0, markerTime, markerPrice);
   else
      ObjectMove(name, 0, markerTime, markerPrice);

   ObjectSetText(name, label, fontSize, "Arial", markerColor);
}

void DrawCornerLabel(string name, string label, color labelColor)
{
   if(ObjectFind(name) == -1)
      ObjectCreate(name, OBJ_LABEL, 0, 0, 0);

   ObjectSet(name, OBJPROP_CORNER, 0);
   ObjectSet(name, OBJPROP_XDISTANCE, 10);
   ObjectSet(name, OBJPROP_YDISTANCE, 15);
   ObjectSetText(name, label, 9, "Arial", labelColor);
}

bool FetchChartSnapshot(string accountId, string symbolName, string timeframeLabel, string &response)
{
   string request =
      "{"
      "\"action\":\"fetch_chart_snapshot\","
      "\"account_id\":\"" + EscapeJson(accountId) + "\","
      "\"symbol\":\"" + EscapeJson(symbolName) + "\","
      "\"timeframe\":\"" + EscapeJson(timeframeLabel) + "\""
      "}";

   string reply = "";
   if(!WsRequest(request, reply))
      return false;

   if(JsonValue(reply, "status") != "ok")
      return false;

   response = JsonValue(reply, "snapshot");
   return response != "";
}

void DrawBridgeSnapshotZone(string timeframeLabel, datetime rightTime, string line, int zoneIndex)
{
   double upper = StrToDouble(CommandValue(line, "upper"));
   double lower = StrToDouble(CommandValue(line, "lower"));
   int originShift = StrToInteger(CommandValue(line, "origin_shift"));
   string kind = CommandValue(line, "kind");
   string family = CommandValue(line, "family");
   string status = CommandValue(line, "status");
   string strength = CommandValue(line, "strength");
   string modeBias = CommandValue(line, "mode");
   color zoneColor = ZoneColorForLine(kind, family, status);
   string objectName = ZonePrefix + "ZONE_" + IntegerToString(zoneIndex);
   datetime leftTime = TimeFromOriginShift(originShift);

   if(lower > upper)
   {
      double swapValue = lower;
      lower = upper;
      upper = swapValue;
   }

   DrawZoneRectangle(
      objectName,
      leftTime,
      rightTime,
      upper,
      lower,
      zoneColor,
      ZoneLabelForLine(timeframeLabel, family, kind, strength, status, modeBias)
   );

   ObjectSet(objectName, OBJPROP_WIDTH, ZoneWidthForLine(family, status));
   ObjectSet(objectName, OBJPROP_STYLE, status == "deleted" ? STYLE_DOT : STYLE_SOLID);
   ObjectSet(objectName, OBJPROP_BACK, status != "deleted");
}

void DrawBridgeSnapshotSwing(string line, int swingIndex)
{
   int originShift = StrToInteger(CommandValue(line, "origin_shift"));
   string kind = CommandValue(line, "kind");
   string source = CommandValue(line, "source");
   string label = CommandValue(line, "label");
   double price = StrToDouble(CommandValue(line, "price"));
   double offset = MathMax(Point * 10.0, ZonePaddingPoints * Point * 0.12);
   datetime markerTime = TimeFromOriginShift(originShift);
   string objectName = ZonePrefix + "SWING_" + IntegerToString(swingIndex);

   if(kind == "high")
      price += offset;
   else
      price -= offset;

   DrawTextMarker(objectName, markerTime, price, SwingLabelForLine(source, label), SwingColorForLine(source, kind), 8);
}

void DrawBridgeSnapshotEvent(datetime rightTime, string line, int eventIndex)
{
   string eventName = CommandValue(line, "event");
   string structureLabel = CommandValue(line, "structure_label");
   string direction = CommandValue(line, "direction");
   double level = StrToDouble(CommandValue(line, "level"));
   color markerColor = direction == "short" ? SupplyColor : direction == "long" ? DemandColor : clrSilver;
   string label = eventName;

   if(structureLabel != "")
      label += " " + structureLabel;

   string objectName = ZonePrefix + "EVENT_" + IntegerToString(eventIndex);

   if(level <= 0.0)
      level = Bid;

   DrawTextMarker(objectName, rightTime, level, label, markerColor, 8);
}

void DrawChartZones()
{
   if(!DrawZonesOnChart)
      return;

   ClearZoneObjects();

   string timeframeLabel = CurrentTimeframeLabel();
   string response = "";
   string summaryObject = ZonePrefix + "SUMMARY";

   if(!FetchChartSnapshot(TerminalAccountId(), Symbol(), timeframeLabel, response))
   {
      DrawCornerLabel(summaryObject, "ZONES waiting for Python chart snapshot...", clrSilver);
      ChartRedraw();
      return;
   }

   ushort newline = 10;
   string lines[];
   int lineCount = StringSplit(response, newline, lines);

   if(lineCount <= 0)
   {
      DrawCornerLabel(summaryObject, "ZONES snapshot was empty.", clrSilver);
      ChartRedraw();
      return;
   }

   int chartSeconds = TimeframeSeconds(Period());
   datetime rightTime = Time[0] + (chartSeconds * ZoneProjectionBars);
   int zoneIndex = 0;
   int swingIndex = 0;
   int eventIndex = 0;

   string header = lines[0];
   StringReplace(header, "\r", "");

   string snapshotStatus = CommandValue(header, "status");
   string resolvedTimeframe = CommandValue(header, "resolved_timeframe");
   string executionAllowed = CommandValue(header, "execution_allowed");
   string executionDirection = CommandValue(header, "execution_direction");
   string zoneCountText = CommandValue(header, "zone_count");
   string swingCountText = CommandValue(header, "swing_count");
   string message = CommandValue(header, "message");

   for(int index = 1; index < lineCount; index++)
   {
      string line = lines[index];
      StringReplace(line, "\r", "");

      if(line == "")
         continue;

      string recordType = LineType(line);

      if(recordType == "zone")
      {
         DrawBridgeSnapshotZone(resolvedTimeframe, rightTime, line, zoneIndex);
         zoneIndex++;
         continue;
      }

      if(recordType == "swing")
      {
         DrawBridgeSnapshotSwing(line, swingIndex);
         swingIndex++;
         continue;
      }

      if(recordType == "event")
      {
         DrawBridgeSnapshotEvent(rightTime, line, eventIndex);
         eventIndex++;
      }
   }

   string summary = "ZONES " + Symbol() + " " + resolvedTimeframe + " | zones " + zoneCountText + " | swings " + swingCountText;

   if(snapshotStatus != "ok")
      summary += " | " + message;
   else if(WireBool(executionAllowed))
      summary += " | execution ON " + executionDirection;
   else
      summary += " | execution OFF " + executionDirection;

   color summaryColor = snapshotStatus == "ok" ? clrWhite : clrSilver;
   DrawCornerLabel(summaryObject, summary, summaryColor);

   ChartRedraw();
}

