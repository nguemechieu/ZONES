void RunBridgeCycle(bool includeAllSymbols)
{
   if(includeAllSymbols)
      PostSnapshots();
   else
      PostSnapshotForSymbol(Symbol());

   DrawChartZones();
   PollCommands();
}

int OnInit()
{
   EventSetTimer(TimerSeconds);

   if(!EnsureWebSocket())
      return(INIT_FAILED);

   string healthReq = "{\"action\":\"health\"}";
   string healthReply = "";
   if(WsRequest(healthReq, healthReply))
      Print("ZONES WS bridge started. Health=", healthReply);
   else
      Print("ZONES WS health check failed.");

   RunBridgeCycle(false);
   return(INIT_SUCCEEDED);
}

void OnDeinit(const int reason)
{
   EventKillTimer();
   ClearZoneObjects();
   g_ws.Close();
}

void OnTimer()
{
   RunBridgeCycle(true);
}

void OnTick()
{
   static datetime lastBarTime = 0;

   if(Time[0] != lastBarTime)
   {
      lastBarTime = Time[0];
      RunBridgeCycle(false);
   }
}